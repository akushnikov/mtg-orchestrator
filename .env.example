# =============================================================================
# MTG Orchestrator — deployment configuration template
#
# Copy this file to .env and fill in the real values on your VPS.
# NEVER commit the real .env — it contains secrets and operator-specific data.
#
# Topology reminder:
#   Moscow VPS  — thin iptables relay (DNAT :443 and :80 → Frankfurt IP)
#   Frankfurt VPS — this Docker stack
#
# The A-record for your domain points to the MOSCOW IP.
# Proxy tg:// links use the MOSCOW IP (MOSCOW_IP below).
# The panel TLS certificate is issued for PANEL_DOMAIN.
# =============================================================================

# ---------------------------------------------------------------------------
# Network — fill in your real IPs / domain before first deploy
# ---------------------------------------------------------------------------

# Public IP of the Moscow relay VPS (used in tg://proxy links).
MOSCOW_IP=1.2.3.4

# Frankfurt VPS public IP (used internally; not in tg:// links).
FRANKFURT_IP=5.6.7.8

# Panel subdomain — must resolve (via A-record on Moscow IP) to your Moscow VPS.
# Example: mtg.yourdomain.ru
PANEL_DOMAIN=mtg.yourdomain.ru

# Let's Encrypt contact email (required for cert issuance and expiry notices).
LE_EMAIL=your@email.example

# ---------------------------------------------------------------------------
# Default mtg instance (compose-managed, always-on)
# ---------------------------------------------------------------------------
# The default mtg instance is the fallback route for unknown SNI on :443.
# Clients with no matching domain in the nginx map will reach this proxy.
#
# Fill these from the currently working mtg setup on the VPS (ria.ru params).
# The secret is the full hex string: ee + 32 hex chars (key) + hex(domain).

MTG_DEFAULT_SECRET=ee0000000000000000000000000000000000000000000000000072696100
MTG_DEFAULT_PORT=3128

# Masquerade domain for the default mtg instance (fake-TLS SNI target).
# Must be reachable from Frankfurt over HTTPS — verify: curl -v https://DOMAIN
MTG_DEFAULT_DOMAIN=ria.ru

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------

# Telegram Bot Token — obtained from @BotFather.
# Used for initData HMAC validation and webhook registration (Phase 3).
BOT_TOKEN=123456789:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Telegram user ID of the bot owner (whitelist — single-user tool).
# Obtain from @userinfobot or similar: send /start to the bot first.
OWNER_USER_ID=123456789

# Secret token for the Telegram webhook endpoint (random string, keep private).
WEBHOOK_SECRET=change-me-to-a-random-secret-string

# Docker socket proxy URL (internal service; do not change unless renaming the service).
DOCKER_HOST=tcp://docker-socket-proxy:2375

# ---------------------------------------------------------------------------
# Certbot / Let's Encrypt
# ---------------------------------------------------------------------------

# Staging flag — set to "--staging" to test without hitting rate limits.
# Leave empty for production cert issuance.
CERTBOT_STAGING=

# ---------------------------------------------------------------------------
# Logging defaults (applied via compose logging: section; documented here
# for reference — not typically loaded as env vars by the app itself)
# ---------------------------------------------------------------------------
# LOG_MAX_SIZE=10m
# LOG_MAX_FILE=3
