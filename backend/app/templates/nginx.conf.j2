{# Generated by backend nginx_service.py - do not edit manually #}
events {
    worker_connections 1024;
}

stream {
    resolver 127.0.0.11 valid=10s ipv6=off;

    map $ssl_preread_server_name $proxy_upstream {
        "{{ panel_domain }}"  backend:8443;
{% for inst in active_instances %}
        "{{ inst.domain }}"  {{ inst.upstream_host | default('mtg-' ~ inst.slug, true) }}:{{ inst.port }};
{% endfor %}
        default  mtg-default:3128;
    }

    server {
        listen 443;
        ssl_preread on;

        proxy_pass $proxy_upstream;
        proxy_connect_timeout 5s;
        proxy_timeout 1h;
    }
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    server {
        listen 80;
        server_name _;

        location /.well-known/acme-challenge/ {
            root /var/www/certbot;
            try_files $uri =404;
        }

        location / {
            return 301 https://$host$request_uri;
        }
    }
}
